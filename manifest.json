{
  "manifest_version": 3,
  "name": "StealthMonkey Pro",
  "version": "2.0",
  "description": "Gerenciador de scripts via Runtime Evaluation",
  "permissions": ["debugger", "storage", "tabs", "scripting" ],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "128": "icon.png"
  },
  "action": {
    "default_icon": { "128": "icon.png" },
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["bridge.js"],
      "run_at": "document_start"
    }
  ]
}